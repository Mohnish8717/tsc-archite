# TSC v2.0 Configuration
# Copy this file to .env and fill in your API keys

# === LLM Provider (choose one or more) ===
# Provider to use: anthropic, openai, groq, openrouter
TSC_LLM_PROVIDER=anthropic
TSC_LLM_MODEL=claude-sonnet-4-20250514

# API Keys (only the one for your chosen provider is required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# === Memory System ===
ZEP_API_KEY=

# === NLP Settings ===
# spaCy model (downloaded on first run)
TSC_SPACY_MODEL=en_core_web_sm
# sentence-transformers model
TSC_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# === Pipeline Settings ===
TSC_MAX_CHUNKS=500
TSC_CHUNK_SIMILARITY_THRESHOLD=0.8
TSC_GATE_FAIL_THRESHOLD=0.5
TSC_MONTE_CARLO_SIMULATIONS=3000

# === Web UI ===
TSC_WEB_HOST=0.0.0.0
TSC_WEB_PORT=8000
